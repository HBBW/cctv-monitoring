# Copy nilai ini ke Environment variables di Portainer Stack kalau mau deploy.

APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost

DB_DATABASE=cctv_exception_monitoring
DB_USERNAME=cctv
DB_PASSWORD=cctv
DB_ROOT_PASSWORD=root

FRONTEND_PORT=80
BACKEND_PORT=8000
MYSQL_PORT=3306
PHPMYADMIN_PORT=8080

# Kosongkan kalau frontend dan backend dibuka dari host yang sama.
# Isi kalau akses pakai IP/domain server, contoh:
# VITE_API_URL=http://192.168.1.10:8000/api
VITE_API_URL=
