# Copy nilai ini ke Environment variables di Portainer Stack kalau mau deploy.

APP_ENV=production
APP_DEBUG=false
APP_URL=https://lab.bmc.co.id
FRONTEND_URL=https://lab.bmc.co.id
APP_DOMAIN=lab.bmc.co.id

DB_DATABASE=cctv_exception_monitoring
DB_USERNAME=cctv
DB_PASSWORD=cctv
DB_ROOT_PASSWORD=root

FRONTEND_PORT=3010
BACKEND_PORT=8010
MYSQL_PORT=3310
PHPMYADMIN_PORT=8586
HTTP_PORT=8081
HTTPS_PORT=443

# Pakai "internal" untuk sertifikat lokal Caddy.
# Browser/device harus trust sertifikat internal ini agar kamera dianggap secure.
# Kalau domain bisa pakai Let's Encrypt, isi email admin, contoh: it@bmc.co.id
CADDY_TLS_MODE=internal

VITE_API_URL=https://lab.bmc.co.id/api
